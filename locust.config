# locust.conf
# ─────────────────────────────────────────────────────────────────────────────
# Default settings for Log Optimization Dashboard load tests.
# Locust reads this file automatically when it's in the same directory.
# Any CLI flag overrides these values.
#
# Usage (uses all defaults below):
#   locust -f locustfile.py
#
# Override on the fly:
#   locust -f locustfile.py -u 100 -r 10 --run-time 5m
# ─────────────────────────────────────────────────────────────────────────────

host           = http://localhost:8001
users          = 20
spawn-rate     = 2
run-time       = 10m
headless       = false
html           = load_test_results/default_report.html
csv            = load_test_results/default
only-summary   = false